<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Wizard's Duel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=EB+Garamond:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a227;
    --gold-bright: #e8c75a;
    --parch: #d8c9a3;
    --dim: #6b5d3f;
    --ink: #0a0a0f;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: "EB Garamond", Georgia, serif;
    background:
      radial-gradient(ellipse at 50% -10%, #2a2418 0%, transparent 55%),
      radial-gradient(ellipse at 50% 120%, #1a1320 0%, transparent 60%),
      #0a0a0f;
    color: var(--parch);
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 24px;
  }
  h1 {
    font-family: "Cinzel", serif; font-size: 26px; font-weight: 700; letter-spacing: 4px;
    color: var(--gold-bright); text-shadow: 0 0 14px rgba(201,162,39,.5), 0 2px 2px #000;
    text-align: center; margin-bottom: 4px;
  }
  .sub { font-style: italic; color: var(--dim); letter-spacing: 1px; margin-bottom: 20px; font-size: 15px; }

  /* ---------- HUD: HP + duel tally ---------- */
  .hud { display: flex; gap: 26px; align-items: center; justify-content: center; margin-bottom: 20px; }
  .hpside .who { font-family: "Cinzel", serif; font-size: 12px; letter-spacing: 2px; color: var(--gold); text-align: center; }
  .pips { display: flex; gap: 6px; justify-content: center; margin-top: 5px; min-height: 14px; }
  .pip { width: 13px; height: 13px; border-radius: 50%;
         background: radial-gradient(circle at 35% 30%, #ffe9a8, #c9a227 70%);
         box-shadow: 0 0 8px rgba(232,199,90,.7); transition: all .3s; }
  .pips.dark .pip { background: radial-gradient(circle at 35% 30%, #ffb070, #ff5a10 70%); box-shadow: 0 0 8px rgba(255,90,16,.7); }
  .pip.lost { background: transparent !important; border: 1px solid var(--dim); box-shadow: none; }
  .tally { font-family: "Cinzel", serif; text-align: center; color: var(--gold-bright); font-size: 18px; letter-spacing: 1px; }
  .tally .tlbl { font-family: "EB Garamond", serif; font-style: italic; font-size: 11px; color: var(--dim); letter-spacing: 2px; }

  /* ---------- stage ---------- */
  .stage {
    position: relative; border: 1px solid var(--gold); border-radius: 4px;
    width: 100%; max-width: 420px; padding: 22px 18px 18px; text-align: center; margin-bottom: 26px;
    background: linear-gradient(180deg, rgba(40,34,20,.55), rgba(10,10,15,.55));
    box-shadow: 0 0 24px rgba(201,162,39,.15), inset 0 0 30px rgba(0,0,0,.6);
  }
  .stage::before, .stage::after {
    content: "✦"; position: absolute; top: -11px; color: var(--gold); font-size: 14px;
    background: #0d0b08; padding: 0 6px;
  }
  .stage::before { left: 14px; }
  .stage::after { right: 14px; }
  .stage.shake { animation: shake .4s ease; }
  .stage.shake-big { animation: shake-big .6s ease; }
  @keyframes shake { 0%{transform:translate(0,0)} 20%{transform:translate(-5px,3px)} 40%{transform:translate(5px,-3px)} 60%{transform:translate(-4px,-2px)} 80%{transform:translate(3px,3px)} 100%{transform:translate(0,0)} }
  @keyframes shake-big { 0%{transform:translate(0,0) rotate(0)} 15%{transform:translate(-10px,6px) rotate(-1deg)} 30%{transform:translate(11px,-6px) rotate(1deg)} 45%{transform:translate(-9px,-5px) rotate(-1deg)} 60%{transform:translate(8px,6px) rotate(.5deg)} 80%{transform:translate(-4px,3px)} 100%{transform:translate(0,0)} }

  /* ---------- duel arena ---------- */
  .arena { position: relative; height: 172px; margin-bottom: 10px; overflow: hidden; }
  .fighter { position: absolute; top: 16px; width: 70px; z-index: 1; }
  .fighter svg { width: 70px; height: 112px; display: block; }
  .fighter .nm { font-family: "Cinzel", serif; font-size: 11px; letter-spacing: 2px; text-align: center; color: var(--gold); margin-top: 2px; }
  .f-gandalf { left: 9%; }
  .f-sauron  { right: 9%; }

  .weapon { position: absolute; top: 40%; left: 50%; transform: translate(-50%,-50%); opacity: 0; pointer-events: none; z-index: 3; color: var(--gold-bright); }
  .wpose { display: inline-block; transform-origin: center; }
  .weapon svg { width: 42px; height: 42px; stroke: currentColor; fill: none; filter: drop-shadow(0 0 8px rgba(232,199,90,.85)); }

  .shard { position: absolute; width: 6px; height: 6px; border-radius: 1px; transform: translate(-50%,-50%); pointer-events: none; z-index: 3; }

  .flash { position: absolute; inset: 0; opacity: 0; pointer-events: none; z-index: 2; }
  .burst {
    position: absolute; top: 4px; left: 50%; transform: translate(-50%,0) scale(.3);
    opacity: 0; pointer-events: none; z-index: 4;
    font-family: "Cinzel", serif; font-size: 19px; font-weight: 700; letter-spacing: 3px;
    color: var(--gold-bright); text-shadow: 0 0 14px rgba(232,199,90,.8), 0 2px 2px #000; white-space: nowrap;
  }

  /* ---------- victor banner ---------- */
  .banner {
    position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: radial-gradient(circle, rgba(10,8,4,.86), rgba(8,6,3,.97)); border-radius: 4px;
    opacity: 0; pointer-events: none; z-index: 10;
  }
  .banner.show { animation: banner-in .6s ease both; pointer-events: auto; }
  .btxt { font-family: "Cinzel", serif; font-size: 23px; font-weight: 700; letter-spacing: 3px; color: var(--gold-bright); text-shadow: 0 0 18px rgba(232,199,90,.8); text-align: center; padding: 0 10px; }
  .bsub { font-style: italic; color: var(--dim); margin-top: 8px; letter-spacing: 1px; }
  @keyframes banner-in { 0%{opacity:0; transform:scale(.8)} 60%{opacity:1; transform:scale(1.05)} 100%{opacity:1; transform:scale(1)} }

  .moverow { display: flex; justify-content: space-around; margin-bottom: 8px; }
  .moverow .move { font-style: italic; font-size: 13px; color: var(--dim); width: 45%; }
  .outcome {
    font-family: "Cinzel", serif; font-size: 15px; letter-spacing: 1px; min-height: 22px;
    color: var(--gold-bright); text-shadow: 0 0 10px rgba(201,162,39,.4);
  }

  /* ---------- result animations ---------- */
  .arena.win  #gandalf { animation: g-lunge 1.2s ease both; }
  .arena.win  #sauron  { animation: s-knock 1.2s ease both; }
  .arena.win  #weapon  { animation: w-right 1.2s ease both; }
  .arena.lose #sauron  { animation: s-lunge 1.2s ease both; }
  .arena.lose #gandalf { animation: g-knock 1.2s ease both; }
  .arena.lose #weapon  { animation: w-left 1.2s ease both; }
  .arena.tie  #gandalf { animation: g-clash 1.2s ease both; }
  .arena.tie  #sauron  { animation: s-clash 1.2s ease both; }
  .arena.tie  #weapon  { animation: w-mid 1.2s ease both; }

  /* finishing blow — the loser falls and stays down */
  .arena.win.finish  #sauron  { animation: s-fall 1.2s ease both; }
  .arena.lose.finish #gandalf { animation: g-fall 1.2s ease both; }
  /* warded blow — Gandalf only flinches and takes no damage */
  .arena.warded #gandalf { animation: g-flinch 1.2s ease both; }

  .arena.win  #flash { animation: flash-imp 1.2s ease both; background: radial-gradient(circle at 70% 44%, rgba(255,236,184,.95), transparent 46%); }
  .arena.lose #flash { animation: flash-imp 1.2s ease both; background: radial-gradient(circle at 30% 44%, rgba(255,72,28,.9),  transparent 46%); }
  .arena.tie  #flash { animation: flash-imp 1.2s ease both; background: radial-gradient(circle at 50% 44%, rgba(255,255,255,.9), transparent 38%); }
  .arena.warded #flash { background: radial-gradient(circle at 30% 44%, rgba(150,255,180,.92), transparent 46%) !important; }

  .arena.win #burst, .arena.lose #burst, .arena.tie #burst { animation: burst-pop 1.2s ease both; }

  /* fighter motion */
  @keyframes g-lunge { 0%{transform:translateX(0) rotate(0)} 22%{transform:translateX(-12px) rotate(-5deg)} 46%{transform:translateX(40px) rotate(8deg)} 62%{transform:translateX(34px)} 100%{transform:translateX(0) rotate(0)} }
  @keyframes s-lunge { 0%{transform:translateX(0) rotate(0)} 22%{transform:translateX(12px) rotate(5deg)} 46%{transform:translateX(-40px) rotate(-8deg)} 62%{transform:translateX(-34px)} 100%{transform:translateX(0) rotate(0)} }
  @keyframes s-knock { 0%,44%{transform:translateX(0) rotate(0); opacity:1} 56%{transform:translateX(22px) rotate(16deg)} 72%{transform:translateX(32px) rotate(26deg)} 88%{transform:translateX(10px) rotate(8deg)} 100%{transform:translateX(0) rotate(0); opacity:1} }
  @keyframes g-knock { 0%,44%{transform:translateX(0) rotate(0); opacity:1} 56%{transform:translateX(-22px) rotate(-16deg)} 72%{transform:translateX(-32px) rotate(-26deg)} 88%{transform:translateX(-10px) rotate(-8deg)} 100%{transform:translateX(0) rotate(0); opacity:1} }
  @keyframes s-fall  { 0%,40%{transform:translateX(0) rotate(0); opacity:1} 55%{transform:translateX(20px) rotate(18deg)} 72%{transform:translateX(34px) rotate(42deg); opacity:.7} 100%{transform:translateX(52px) rotate(90deg) translateY(30px); opacity:0} }
  @keyframes g-fall  { 0%,40%{transform:translateX(0) rotate(0); opacity:1} 55%{transform:translateX(-20px) rotate(-18deg)} 72%{transform:translateX(-34px) rotate(-42deg); opacity:.7} 100%{transform:translateX(-52px) rotate(-90deg) translateY(30px); opacity:0} }
  @keyframes g-flinch { 0%,44%{transform:translateX(0) rotate(0)} 56%{transform:translateX(-15px) rotate(-7deg)} 74%{transform:translateX(-5px) rotate(-2deg)} 100%{transform:translateX(0) rotate(0)} }
  @keyframes g-clash { 0%{transform:translateX(0)} 42%{transform:translateX(26px)} 56%{transform:translateX(22px)} 72%{transform:translateX(-8px)} 100%{transform:translateX(0)} }
  @keyframes s-clash { 0%{transform:translateX(0)} 42%{transform:translateX(-26px)} 56%{transform:translateX(-22px)} 72%{transform:translateX(8px)} 100%{transform:translateX(0)} }

  /* weapon travel (position only — pose handles rotation/scale) */
  @keyframes w-right { 0%{left:34%; opacity:0} 22%{opacity:1} 50%{left:66%} 62%{left:66%; opacity:1} 80%,100%{left:66%; opacity:0} }
  @keyframes w-left  { 0%{left:66%; opacity:0} 22%{opacity:1} 50%{left:34%} 62%{left:34%; opacity:1} 80%,100%{left:34%; opacity:0} }
  @keyframes w-mid   { 0%{left:50%; opacity:0} 24%{opacity:1} 62%{opacity:1} 80%,100%{opacity:0} }

  /* weapon-specific strike poses */
  .wpose.pose-stone  { animation: pose-stone  1.2s ease both; }  /* hurl + spin */
  .wpose.pose-blade  { animation: pose-blade  1.2s ease both; }  /* slashing arc */
  .wpose.pose-scroll { animation: pose-scroll 1.2s ease both; }  /* unfurl */
  @keyframes pose-stone  { 0%,22%{transform:rotate(0) scale(.5)} 50%{transform:rotate(360deg) scale(1.2)} 60%{transform:rotate(388deg) scale(1.1)} 100%{transform:rotate(388deg) scale(1)} }
  @keyframes pose-blade  { 0%,24%{transform:rotate(-120deg) scale(.6)} 42%{transform:rotate(-30deg) scale(1)} 52%{transform:rotate(80deg) scale(1.3)} 62%{transform:rotate(120deg) scale(1.1)} 100%{transform:rotate(120deg) scale(1)} }
  @keyframes pose-scroll { 0%,22%{transform:scaleX(.2) scaleY(.7)} 44%{transform:scaleX(1.35) scaleY(1.1)} 56%{transform:scaleX(1.1) scaleY(1)} 100%{transform:scaleX(1.1) scaleY(1)} }

  @keyframes flash-imp { 0%,42%{opacity:0} 52%{opacity:.9} 72%{opacity:0} 100%{opacity:0} }
  @keyframes burst-pop { 0%,46%{opacity:0; transform:translate(-50%,0) scale(.3)} 56%{opacity:1; transform:translate(-50%,0) scale(1.25)} 72%{transform:translate(-50%,0) scale(1)} 92%{opacity:1} 100%{opacity:0} }

  /* ---------- die of fate ---------- */
  .dice-panel {
    position: fixed; left: 26px; top: 50%; transform: translateY(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 11px; z-index: 5;
  }
  .dice-label { font-family: "Cinzel", serif; font-size: 11px; letter-spacing: 2px; color: var(--gold); }
  .d20 { position: relative; width: 96px; height: 96px; transition: transform .2s, filter .2s; }
  .d20 svg { width: 100%; height: 100%; display: block; }
  .d20 .dnum {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    font-family: "Cinzel", serif; font-weight: 700; font-size: 30px; color: var(--gold-bright);
    text-shadow: 0 0 10px rgba(232,199,90,.7); padding-bottom: 6px;
  }
  .d20.ready { cursor: pointer; filter: drop-shadow(0 0 10px rgba(232,199,90,.45)); }
  .d20.ready:hover { transform: scale(1.06); }
  .d20.spent { opacity: .6; }
  .d20.ward  { filter: drop-shadow(0 0 16px rgba(120,255,160,.85)); }
  .d20.curse { filter: drop-shadow(0 0 16px rgba(255,70,46,.9)); }
  .d20.rolling { animation: diceRoll .78s ease; }
  @keyframes diceRoll { 0%{transform:rotate(0) scale(1)} 25%{transform:rotate(200deg) scale(1.12)} 50%{transform:rotate(380deg) scale(.94)} 75%{transform:rotate(560deg) scale(1.1)} 100%{transform:rotate(720deg) scale(1)} }
  .dice-state { font-style: italic; font-size: 12px; color: var(--dim); text-align: center; max-width: 132px; min-height: 48px; }
  @media (max-width: 600px) {
    .dice-panel { position: static; transform: none; flex-direction: row; flex-wrap: wrap; justify-content: center; margin-bottom: 18px; gap: 10px; }
    .dice-state { min-height: 0; }
  }

  /* ---------- choices & controls ---------- */
  .choices { display: flex; gap: 14px; transition: opacity .3s; }
  .choices.locked { opacity: .35; pointer-events: none; filter: grayscale(.5); }
  .choice {
    font-family: "Cinzel", serif;
    background: linear-gradient(180deg, rgba(40,34,20,.6), rgba(10,10,15,.6));
    color: var(--parch); border: 1px solid var(--gold); border-radius: 4px;
    padding: 14px 14px 10px; width: 96px; cursor: pointer; transition: all .12s ease;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .choice svg { width: 40px; height: 40px; stroke: var(--parch); fill: none; transition: stroke .12s; }
  .choice .label { font-size: 12px; letter-spacing: 2px; color: var(--gold); }
  .choice:hover { border-color: var(--gold-bright); box-shadow: 0 0 16px rgba(232,199,90,.4); transform: translateY(-2px); }
  .choice:hover svg { stroke: var(--gold-bright); }
  .choice:active { transform: translateY(0); }

  .controls { margin-top: 24px; display: flex; gap: 12px; }
  .rune-btn {
    font-family: "Cinzel", serif; font-size: 11px; letter-spacing: 2px;
    background: transparent; color: var(--gold); border: 1px solid var(--dim);
    border-radius: 3px; padding: 7px 14px; cursor: pointer; transition: all .12s;
  }
  .rune-btn:hover { border-color: var(--gold); color: var(--gold-bright); }
</style>
</head>
<body>
  <h1>The Wizard's Duel</h1>
  <div class="sub">Stone &middot; Scroll &middot; Blade</div>

  <div class="dice-panel">
    <div class="dice-label">Die of Fate</div>
    <div class="d20 ready" id="d20" title="Roll once per duel">
      <svg viewBox="0 0 100 100" fill="none" stroke="#c9a227" stroke-width="2" stroke-linejoin="round">
        <polygon points="50,3 90,26 90,74 50,97 10,74 10,26" fill="rgba(40,34,20,.6)"/>
        <polygon points="50,18 78,66 22,66" fill="rgba(201,162,39,.1)"/>
        <path d="M50 18 L50 3 M50 18 L90 26 M50 18 L10 26 M78 66 L90 74 M78 66 L90 26 M78 66 L50 97 M22 66 L10 74 M22 66 L10 26 M22 66 L50 97" stroke-width="1.3" stroke-opacity=".7"/>
      </svg>
      <span class="dnum" id="dnum">20</span>
    </div>
    <button class="rune-btn" id="rollBtn">Roll Fate</button>
    <div class="dice-state" id="diceState">1 roll per duel</div>
  </div>

  <div class="hud">
    <div class="hpside"><div class="who">Gandalf</div><div class="pips" id="ghp"></div></div>
    <div class="tally"><span id="dyou">0</span> &mdash; <span id="dcpu">0</span><div class="tlbl">duels</div></div>
    <div class="hpside"><div class="who">Sauron</div><div class="pips dark" id="shp"></div></div>
  </div>

  <div class="stage">
    <div class="arena" id="arena">
      <div class="fighter f-gandalf" id="gandalf"></div>
      <div class="fighter f-sauron" id="sauron"></div>
      <div class="weapon" id="weapon"><div class="wpose" id="wpose"></div></div>
      <div class="flash" id="flash"></div>
      <div class="burst" id="burst"></div>
    </div>
    <div class="moverow">
      <span class="move" id="youMove">&mdash;</span>
      <span class="move" id="cpuMove">&mdash;</span>
    </div>
    <div class="outcome" id="outcome">Cast thy choice</div>
    <div class="banner" id="banner"><div class="btxt" id="btxt"></div><div class="bsub">Press New Duel to fight again</div></div>
  </div>

  <div class="choices" id="choices"></div>

  <div class="controls">
    <button class="rune-btn" id="reset">New Duel</button>
    <button class="rune-btn" id="music">Music: Off</button>
  </div>

<script>
  /* ---------------- weapon / move icons ---------------- */
  const ICONS = {
    stone:  '<svg viewBox="0 0 48 48" fill="none" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><path d="M10 34 L7 22 L16 12 L30 10 L41 20 L40 34 Z"/><path d="M16 12 L20 24 L7 22"/><path d="M20 24 L30 10"/><path d="M20 24 L40 34"/></svg>',
    scroll: '<svg viewBox="0 0 48 48" fill="none" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><path d="M14 10 h22 a4 4 0 0 1 0 8 h-4"/><path d="M12 38 h22 a4 4 0 0 0 0 -8 h-22 a4 4 0 0 0 0 8 a4 4 0 0 0 4 -4 v-20 a4 4 0 0 0 -4 -4 a4 4 0 0 0 -4 4 a4 4 0 0 0 4 4 h4"/><path d="M20 22 h8 M20 27 h6"/></svg>',
    blade:  '<svg viewBox="0 0 48 48" fill="none" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><path d="M34 8 L20 30 L18 34 L22 32 Z"/><path d="M14 30 L24 40"/><path d="M12 33 L16 29 M21 38 L25 34"/><path d="M16 36 L10 42"/></svg>'
  };

  /* ---------------- fighter figures ---------------- */
  const GANDALF = '<svg viewBox="0 0 70 112">' +
    '<line x1="9" y1="34" x2="9" y2="108" stroke="#caa84a" stroke-width="3" stroke-linecap="round"/>' +
    '<circle cx="9" cy="31" r="4.5" fill="#e8c75a"/>' +
    '<path d="M20 60 L11 108 L55 108 L46 60 Z" fill="#cfc9bb"/>' +
    '<path d="M22 62 L11 84" stroke="#b3ad9c" stroke-width="6" fill="none" stroke-linecap="round"/>' +
    '<path d="M25 56 L33 84 L41 56 Z" fill="#eee7d4"/>' +
    '<circle cx="33" cy="50" r="8.5" fill="#ece5d2"/>' +
    '<path d="M13 42 Q33 31 53 42 Q33 47 13 42Z" fill="#b8b2a0"/>' +
    '<path d="M18 42 L33 8 L48 42 Z" fill="#cfc9bb"/>' +
    '</svg><div class="nm">Gandalf</div>';

  const SAURON = '<svg viewBox="0 0 70 112">' +
    '<path d="M16 58 L7 108 L63 108 L54 58 Z" fill="#191920"/>' +
    '<path d="M18 60 L11 46 L26 58 Z" fill="#26262e"/>' +
    '<path d="M52 60 L59 46 L44 58 Z" fill="#26262e"/>' +
    '<path d="M24 34 Q35 20 46 34 L46 54 Q35 62 24 54 Z" fill="#141419"/>' +
    '<path d="M24 34 Q12 16 18 8 Q24 22 31 32 Z" fill="#0d0d12"/>' +
    '<path d="M46 34 Q58 16 52 8 Q46 22 39 32 Z" fill="#0d0d12"/>' +
    '<ellipse cx="35" cy="44" rx="7" ry="3.6" fill="#ff7a18" style="filter:drop-shadow(0 0 6px #ff5a10)"/>' +
    '<ellipse cx="35" cy="44" rx="2.6" ry="3.2" fill="#ffe0a0"/>' +
    '</svg><div class="nm">Sauron</div>';

  /* ---------------- moves & rules ---------------- */
  const MOVES = [ {id:"stone",label:"Stone"}, {id:"scroll",label:"Scroll"}, {id:"blade",label:"Blade"} ];
  const BEATS = { stone:"blade", scroll:"stone", blade:"scroll" };
  const VERB  = { stone:"shatters", scroll:"smothers", blade:"shreds" };
  const LABEL = Object.fromEntries(MOVES.map(m => [m.id, m.label]));

  /* ---------------- audio (Web Audio API) ---------------- */
  let actx = null;
  const N = {
    C3:130.81, D3:146.83, E3:164.81, F3:174.61, G3:196.00, A3:220.00, Bb3:233.08,
    C4:261.63, D4:293.66, E4:329.63, F4:349.23, G4:392.00, A4:440.00, Bb4:466.16, B4:493.88,
    C5:523.25, D5:587.33, E5:659.25, A5:880.00, A2:110.00, Bb2:116.54, D2:73.42, F2:87.31, G2:98.00
  };
  function audio() {
    if (!actx) actx = new (window.AudioContext || window.webkitAudioContext)();
    if (actx.state === "suspended") actx.resume();
    return actx;
  }
  function tone(freq, t, dur, vol = 0.16, type = "triangle") {
    const a = audio(), osc = a.createOscillator(), gain = a.createGain();
    osc.type = type; osc.frequency.value = freq;
    const start = a.currentTime + t;
    gain.gain.setValueAtTime(0.0001, start);
    gain.gain.exponentialRampToValueAtTime(vol, start + 0.02);
    gain.gain.exponentialRampToValueAtTime(0.0001, start + dur);
    osc.connect(gain).connect(a.destination);
    osc.start(start); osc.stop(start + dur + 0.05);
  }
  const SFX = {
    win:  () => { [N.D4,N.F4,N.A4,N.D5,N.A5].forEach((f,i)=>tone(f, i*0.10, 0.7, 0.16, "triangle")); tone(N.A5,0.55,1.1,0.07,"sine"); },
    lose: () => { [N.A3,N.F3,N.D3,N.A2].forEach((f,i)=>tone(f, i*0.16, 0.9, 0.18, "sawtooth")); tone(N.D2,0.1,1.6,0.10,"sine"); },
    tie:  () => { tone(N.A3,0,0.9,0.14,"sine"); tone(N.A3*1.5,0.04,0.9,0.06,"triangle"); },
    victory: () => { [N.D4,N.F4,N.A4,N.D5,N.A5].forEach((f,i)=>tone(f, i*0.12, 1.0, 0.16, "triangle")); tone(N.D5,0.7,1.4,0.06,"sine"); },
    doom:    () => { [N.A2,N.G2,N.F2,N.D2].forEach((f,i)=>tone(f, i*0.18, 1.2, 0.2, "sawtooth")); tone(N.D2,0,2.0,0.12,"sine"); },
    ward:    () => { [N.A4,N.C5,N.E5].forEach((f,i)=>tone(f, i*0.07, 0.55, 0.13, "sine")); tone(N.A5,0.18,0.7,0.05,"triangle"); },
    curse:   () => { [N.D3,N.A2].forEach((f,i)=>tone(f, i*0.10, 0.8, 0.16, "sawtooth")); tone(N.D2,0,1.2,0.08,"sine"); },
  };

  /* ---------------- looping theme (D minor) ---------------- */
  const LEAD = ["D4","A4","F4","A4","G4","D5","A4","F4","E4","A4","C5","A4","F4","D4","E4","A3"];
  const BASS = ["D3","D3","Bb2","Bb2","F3","F3","A2","A2","D3","D3","G2","G2","A2","A2","D3","D3"];
  const STEP_MS = 340;
  let musicOn = false, musicTimer = null, step = 0;
  function musicTick() {
    const lf = N[LEAD[step % LEAD.length]], bf = N[BASS[step % BASS.length]];
    tone(lf, 0, STEP_MS/1000*1.4, 0.07, "triangle");
    tone(lf/2, 0, STEP_MS/1000*1.2, 0.025, "sine");
    if (step % 2 === 0) tone(bf, 0, STEP_MS/1000*2.2, 0.10, "sine");
    step++;
  }
  function startMusic(){ audio(); musicOn=true; step=0; musicTick(); musicTimer=setInterval(musicTick,STEP_MS); document.getElementById("music").textContent="Music: On"; }
  function stopMusic(){ musicOn=false; clearInterval(musicTimer); musicTimer=null; document.getElementById("music").textContent="Music: Off"; }

  /* ---------------- refs & state ---------------- */
  const arena  = document.getElementById("arena");
  const stage  = document.querySelector(".stage");
  const weapon = document.getElementById("weapon");
  const wpose  = document.getElementById("wpose");
  const burst  = document.getElementById("burst");
  const banner = document.getElementById("banner");
  const choicesEl = document.getElementById("choices");
  const el = {
    youMove: document.getElementById("youMove"), cpuMove: document.getElementById("cpuMove"),
    outcome: document.getElementById("outcome"),
    ghp: document.getElementById("ghp"), shp: document.getElementById("shp"),
    dyou: document.getElementById("dyou"), dcpu: document.getElementById("dcpu"),
    btxt: document.getElementById("btxt"),
  };

  const d20 = document.getElementById("d20");
  const dnum = document.getElementById("dnum");
  const diceState = document.getElementById("diceState");
  let diceRolled = false, pendingMod = null;   // pendingMod: null | "ward" | "curse"

  document.getElementById("gandalf").innerHTML = GANDALF;
  document.getElementById("sauron").innerHTML  = SAURON;

  const MAX_HP = 3;
  let hp = { you: MAX_HP, cpu: MAX_HP };
  let duels = { you: 0, cpu: 0 };
  let over = false;

  function pips(n){ let s=""; for(let i=0;i<MAX_HP;i++) s += '<span class="pip'+(i<n?'':' lost')+'"></span>'; return s; }
  function renderHP(){ el.ghp.innerHTML = pips(hp.you); el.shp.innerHTML = pips(hp.cpu); }
  renderHP();

  /* ---------------- die of fate ---------------- */
  function setDiceState(txt, kind){
    diceState.textContent = txt;
    diceState.style.color = kind === "ward" ? "#8effb0" : kind === "curse" ? "#ff6a4a" : "var(--dim)";
  }
  function rollDice(){
    if (diceRolled || over) return;
    diceRolled = true;
    d20.classList.remove("ready");
    d20.classList.add("rolling");
    let ticks = 0;
    const iv = setInterval(() => {
      dnum.textContent = 1 + Math.floor(Math.random()*20);
      tone(420 + Math.random()*260, 0, 0.03, 0.04, "square");   // dice rattle
      if (++ticks >= 12) { clearInterval(iv); settle(); }
    }, 60);
    function settle(){
      const r = 1 + Math.floor(Math.random()*20);
      dnum.textContent = r;
      d20.classList.remove("rolling");
      d20.classList.add("spent");
      if (r >= 10) {
        pendingMod = "ward"; d20.classList.add("ward");
        setDiceState("Rolled " + r + " — Ward: the next blow will not wound.", "ward");
        SFX.ward();
      } else {
        pendingMod = "curse"; d20.classList.add("curse");
        setDiceState("Rolled " + r + " — Curse: the next blow strikes twice.", "curse");
        SFX.curse();
      }
    }
  }
  function consumeDice(kind){
    pendingMod = null;
    d20.classList.remove("ward","curse");
    setDiceState(kind === "ward" ? "Ward spent — Gandalf stands unscathed." : "Curse spent — the blow struck twice.", null);
  }

  /* ---------------- effects ---------------- */
  const PAL = {
    win:  ["#e8c75a","#fff0c0","#caa84a"],
    lose: ["#ff7a18","#ff3b1e","#7a1414"],
    tie:  ["#ffffff","#d8c9a3","#e8c75a"],
  };
  function particles(xPct, palette, count){
    for (let i=0;i<count;i++){
      const p = document.createElement("div");
      p.className = "shard";
      p.style.left = xPct + "%";
      p.style.top = "44%";
      p.style.background = palette[i % palette.length];
      const sz = 4 + Math.random()*5;
      p.style.width = p.style.height = sz + "px";
      arena.appendChild(p);
      const ang = Math.random()*Math.PI*2;
      const dist = 24 + Math.random()*52;
      const dx = Math.cos(ang)*dist, dy = Math.sin(ang)*dist - 8;
      const rot = Math.random()*540 - 270;
      const dur = 420 + Math.random()*420;
      const a = p.animate(
        [ {transform:"translate(-50%,-50%) rotate(0deg) scale(1)", opacity:1},
          {transform:"translate("+dx+"px,"+dy+"px) rotate("+rot+"deg) scale(.15)", opacity:0} ],
        {duration:dur, easing:"cubic-bezier(.2,.6,.3,1)"});
      a.onfinish = () => p.remove();
    }
  }
  function shakeStage(cls){
    if (!cls) return;
    stage.classList.remove("shake","shake-big");
    void stage.offsetWidth;
    stage.classList.add(cls);
    setTimeout(() => stage.classList.remove(cls), 700);
  }

  function animate(result, tool, finishing, opts){
    opts = opts || {};
    wpose.innerHTML = ICONS[tool];
    burst.textContent = opts.burst || (result === "win" ? "✦ STRIKE ✦" : result === "lose" ? "✦ FELLED ✦" : "✦ CLASH ✦");
    arena.className = "arena";
    wpose.className = "wpose";
    void arena.offsetWidth;                 // restart animations
    arena.classList.add(result);
    if (finishing) arena.classList.add("finish");
    if (opts.extra) arena.classList.add(opts.extra);
    wpose.classList.add("pose-" + tool);

    const xPct = result === "win" ? 66 : result === "lose" ? 34 : 50;
    const pal = opts.pal || PAL[result];
    const count = opts.count != null ? opts.count : (finishing ? 28 : 13);
    setTimeout(() => {
      renderHP();                           // HP drops in sync with the blow
      particles(xPct, pal, count);
      if (result !== "tie") shakeStage(finishing ? "shake-big" : "shake");
    }, 560);

    if (finishing) setTimeout(showBanner, 1000);
  }

  function showBanner(){
    const youWon = hp.you > 0;
    el.btxt.textContent = "✦ " + (youWon ? "GANDALF" : "SAURON") + " PREVAILS ✦";
    banner.classList.add("show");
    choicesEl.classList.add("locked");
    particles(youWon ? 30 : 70, youWon ? PAL.win : PAL.lose, 30);
    (youWon ? SFX.victory : SFX.doom)();
  }

  /* ---------------- game ---------------- */
  function play(you){
    if (over) return;
    const cpu = MOVES[Math.floor(Math.random()*3)].id;
    el.youMove.textContent = LABEL[you];
    el.cpuMove.textContent = LABEL[cpu];

    let result, text, tool, finishing = false, opts;
    if (you === cpu) {
      result = "tie"; tool = you; text = "A stalemate"; SFX.tie();
    } else if (BEATS[you] === cpu) {
      result = "win"; tool = you;  text = LABEL[you] + " " + VERB[you] + " " + LABEL[cpu];
      hp.cpu--; SFX.win();
      if (hp.cpu <= 0) { finishing = true; over = true; duels.you++; }
    } else {
      result = "lose"; tool = cpu;
      const base = LABEL[cpu] + " " + VERB[cpu] + " " + LABEL[you];
      let dmg = 1;
      const mod = pendingMod;
      if (mod === "ward")  { dmg = 0; consumeDice("ward"); }
      if (mod === "curse") { dmg = 2; consumeDice("curse"); }
      if (mod === "ward")       { text = base + " — but the ward holds!"; opts = { burst: "✦ WARDED ✦", pal: PAL.win, extra: "warded" }; }
      else if (mod === "curse") { text = base + " — the curse bites twice!"; opts = { burst: "✦ CURSED ✦", count: 22 }; }
      else                      { text = base; }
      hp.you -= dmg; if (hp.you < 0) hp.you = 0;
      SFX.lose();
      if (hp.you <= 0) { finishing = true; over = true; duels.cpu++; }
    }
    el.outcome.textContent = text;
    el.dyou.textContent = duels.you;
    el.dcpu.textContent = duels.cpu;
    animate(result, tool, finishing, opts);
  }

  /* build choice buttons */
  MOVES.forEach(m => {
    const b = document.createElement("button");
    b.className = "choice";
    b.innerHTML = ICONS[m.id] + '<span class="label">' + m.label + '</span>';
    b.addEventListener("click", () => play(m.id));
    choicesEl.appendChild(b);
  });

  document.getElementById("rollBtn").addEventListener("click", rollDice);
  d20.addEventListener("click", rollDice);

  document.getElementById("music").addEventListener("click", () => musicOn ? stopMusic() : startMusic());
  document.getElementById("reset").addEventListener("click", () => {
    hp = { you: MAX_HP, cpu: MAX_HP };
    over = false;
    renderHP();
    banner.classList.remove("show");
    choicesEl.classList.remove("locked");
    arena.className = "arena";
    wpose.className = "wpose";
    el.youMove.innerHTML = el.cpuMove.innerHTML = "&mdash;";
    el.outcome.textContent = "Cast thy choice";
    // reset the Die of Fate for the new duel
    diceRolled = false; pendingMod = null;
    d20.className = "d20 ready"; dnum.textContent = "20";
    setDiceState("1 roll per duel", null);
  });
</script>
</body>
</html>
